# Copy these into Railway → your service → Variables tab
# DO NOT commit this file with real values

AXI_EMAIL=your_axi_affiliate_email@example.com
AXI_PASSWORD=your_axi_password

TG_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_or_channel_id

# Optional — defaults shown
WITHDRAWAL_THRESHOLD=0.50   # 50% — flag anyone who withdrew more than this
CHECK_HOUR=9                # UTC hour to run daily scan (9 = 09:00 UTC)
CHECK_MINUTE=0
